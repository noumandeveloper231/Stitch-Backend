MONGO_URI=mongodb://127.0.0.1:27017/stitchflow
PORT=5000
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
REFRESH_TOKEN_DAYS=7
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Invoice PDF header (optional)
SHOP_NAME=Stitch Tailor
SHOP_ADDRESS=
SHOP_PHONE=

# Notifications (optional)
NOTIFICATION_DELIVERY_SOON_DAYS=3
NOTIFICATION_STALE_PENDING_DAYS=7
